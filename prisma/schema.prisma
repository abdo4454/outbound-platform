// ============================================================
// Outbound Marketing Agency — Database Schema (SQLite)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  avatar        String?
  emailVerified Boolean   @default(false)

  resetToken    String?   @unique
  resetTokenExp DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]

  @@index([email])
}

// ============================================================
// MULTI-TENANCY
// ============================================================

model Organization {
  id         String  @id @default(cuid())
  clerkOrgId String? @unique
  name       String
  slug       String  @unique
  inviteCode String  @unique @default(cuid())
  logo       String?
  website    String?
  industry   String?

  // plan: STARTER | GROWTH | SCALE | ENTERPRISE
  plan   String @default("STARTER")
  // status: ONBOARDING | ACTIVE | PAUSED | CHURNED
  status String @default("ONBOARDING")

  // Credits for unlocking contacts in the global data catalog
  creditBalance Int @default(0)

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  billingEmail         String?
  mrr                  Int     @default(0)

  // Stored as JSON string
  brandColors String?
  timezone    String @default("America/New_York")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      Member[]
  campaigns    Campaign[]
  contacts     Contact[]
  leads        Lead[]
  deals        Deal[]
  reports      Report[]
  onboarding   Onboarding?
  invoices     Invoice[]
  activityLogs ActivityLog[]
  integrations Integration[]
  invites      UserInvite[]

  @@index([clerkOrgId])
  @@index([slug])
  @@index([stripeCustomerId])
}

model Member {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  email  String
  name   String
  avatar String?
  // role: ADMIN | CLIENT_ADMIN | MANAGER | VIEWER
  role   String @default("VIEWER")

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedDeals Deal[]
  activityLogs  ActivityLog[]

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
}

model UserInvite {
  id    String @id @default(cuid())
  email String
  token String @unique @default(cuid())
  // role: ADMIN | CLIENT_ADMIN | MANAGER | VIEWER
  role  String @default("VIEWER")

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  expiresAt  DateTime
  acceptedAt DateTime?

  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
  @@index([orgId])
}

// ============================================================
// LEAD CAPTURE & ATTRIBUTION
// ============================================================

model Lead {
  id      String  @id @default(cuid())
  email   String
  name    String?
  company String?
  phone   String?
  website String?
  message String?

  source      String?
  medium      String?
  campaign    String?
  content     String?
  term        String?
  landingPage String?
  referrer    String?
  gclid       String?
  fbclid      String?

  firstTouchSource String?
  firstTouchMedium String?
  lastTouchSource  String?
  lastTouchMedium  String?

  companySize String?
  budget      String?
  interest    String?
  icpScore    Int?

  pagesViewed       Int     @default(0)
  timeOnSite        Int     @default(0)
  chatEngaged       Boolean @default(false)
  // Stored as JSON array string
  contentDownloaded String  @default("[]")

  // status: NEW | CONTACTED | QUALIFIED | DISCOVERY_BOOKED | DISCOVERY_COMPLETE | PROPOSAL_SENT | NEGOTIATION | WON | LOST | DISQUALIFIED
  status      String    @default("NEW")
  convertedAt DateTime?

  // Stored as JSON string
  enrichmentData String?
  linkedinUrl    String?
  industry       String?
  jobTitle       String?

  orgId  String?
  org    Organization? @relation(fields: [orgId], references: [id])
  dealId String?
  deal   Deal?         @relation(fields: [dealId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([orgId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// PIPELINE & DEALS
// ============================================================

model Deal {
  id       String @id @default(cuid())
  title    String
  value    Int    @default(0)
  currency String @default("usd")
  // stage: DISCOVERY_BOOKED | DISCOVERY_COMPLETE | PROPOSAL_SENT | NEGOTIATION | CLOSED_WON | CLOSED_LOST
  stage    String @default("DISCOVERY_BOOKED")

  probability    Int     @default(20)
  contractLength Int?
  setupFee       Int?
  startDate      DateTime?
  closeDate      DateTime?
  lostReason     String?
  // Stored as JSON array string
  services       String  @default("[]")

  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   Member?      @relation(fields: [assignedToId], references: [id])
  leads        Lead[]
  notes        DealNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([stage])
  @@index([createdAt])
}

model DealNote {
  id       String @id @default(cuid())
  content  String
  dealId   String
  deal     Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId String

  createdAt DateTime @default(now())

  @@index([dealId])
}

// ============================================================
// CAMPAIGNS & METRICS
// ============================================================

model Campaign {
  id String @id @default(cuid())
  name String
  // status: DRAFT | ACTIVE | PAUSED | COMPLETED | ARCHIVED
  status String @default("DRAFT")
  // type: COLD_EMAIL | LINKEDIN | MULTI_CHANNEL
  type   String @default("COLD_EMAIL")

  externalId   String?
  externalTool String?

  sendingEmail   String?
  sendingDomain  String?
  dailyLimit     Int?
  targetAudience String?

  orgId     String
  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  metrics   CampaignMetric[]
  sequences Sequence[]

  startedAt DateTime?
  pausedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orgId])
  @@index([status])
}

model CampaignMetric {
  id   String   @id @default(cuid())
  date DateTime

  emailsSent      Int @default(0)
  emailsDelivered Int @default(0)
  bounces         Int @default(0)
  opens           Int @default(0)
  uniqueOpens     Int @default(0)
  clicks          Int @default(0)
  replies         Int @default(0)
  positiveReplies Int @default(0)
  meetingsBooked  Int @default(0)
  meetingsHeld    Int @default(0)
  noShows         Int @default(0)
  spamComplaints  Int @default(0)
  unsubscribes    Int @default(0)

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([campaignId, date])
  @@index([date])
  @@index([campaignId])
}

model Sequence {
  id     String @id @default(cuid())
  name   String
  // Stored as JSON string
  steps  String @default("[]")
  status String @default("draft")

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
}

// ============================================================
// CONTACTS
// ============================================================

model Contact {
  id            String  @id @default(cuid())
  email         String
  firstName     String?
  lastName      String?
  phone         String?
  jobTitle      String?
  company       String?
  companyDomain String?
  linkedinUrl   String?
  location      String?
  state         String?
  industry      String?

  enrichedAt     DateTime?
  // Stored as JSON string
  enrichmentData String?

  // status: ACTIVE | BOUNCED | UNSUBSCRIBED | REPLIED | MEETING_BOOKED | DO_NOT_CONTACT
  status String  @default("ACTIVE")
  // Stored as JSON array string
  tags   String  @default("[]")

  // Global catalog flag — these contacts are visible to all orgs (with credit gating)
  isGlobal Boolean @default(false)

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  unlocks ContactUnlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([email])
  @@index([status])
  @@index([isGlobal])
}

model ContactUnlock {
  id         String   @id @default(cuid())
  orgId      String
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([orgId, contactId])
  @@index([orgId])
}

// ============================================================
// CLIENT ONBOARDING
// ============================================================

model Onboarding {
  id String @id @default(cuid())

  icpComplete       Boolean @default(false)
  messagingComplete Boolean @default(false)
  domainComplete    Boolean @default(false)
  assetsComplete    Boolean @default(false)
  crmComplete       Boolean @default(false)
  calendarComplete  Boolean @default(false)
  approvalComplete  Boolean @default(false)

  // All stored as JSON array strings
  targetIndustries   String @default("[]")
  targetCompanySizes String @default("[]")
  targetGeographies  String @default("[]")
  targetTitles       String @default("[]")
  exclusions         String @default("[]")

  valueProps      String @default("[]")
  tonePreference  String?
  painPoints      String @default("[]")
  differentiators String @default("[]")
  avoidPhrases    String @default("[]")

  sendingDomains String @default("[]")
  // Stored as JSON string
  emailAccounts  String?

  // Stored as JSON string
  assets String?

  crmType      String?
  crmConnected Boolean @default(false)

  calendarProvider  String?
  calendarConnected Boolean @default(false)
  bookingLink       String?

  launchDate DateTime?
  approvedBy String?
  approvedAt DateTime?

  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// BILLING & INVOICES
// ============================================================

model Invoice {
  id              String  @id @default(cuid())
  stripeInvoiceId String  @unique
  amount          Int
  currency        String  @default("usd")
  // status: DRAFT | OPEN | PAID | VOID | UNCOLLECTIBLE
  status          String
  paidAt          DateTime?
  dueDate         DateTime?
  pdfUrl          String?

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([status])
}

// ============================================================
// REPORTS
// ============================================================

model Report {
  id     String @id @default(cuid())
  // type: WEEKLY | MONTHLY | QUARTERLY
  type   String
  period String
  title  String
  // Stored as JSON string
  data   String @default("{}")
  pdfUrl String?
  sentAt DateTime?

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([type, period])
}

// ============================================================
// INTEGRATIONS
// ============================================================

model Integration {
  id     String @id @default(cuid())
  type   String
  status String @default("connected")

  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?

  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?

  // Stored as JSON string
  metadata String?

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, type])
  @@index([orgId])
}

// ============================================================
// ACTIVITY LOG & AUDIT TRAIL
// ============================================================

model ActivityLog {
  id        String  @id @default(cuid())
  action    String
  // Stored as JSON string
  details   String?
  ipAddress String?

  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  memberId String?
  member   Member?      @relation(fields: [memberId], references: [id])

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================
// REFERRAL PROGRAM
// ============================================================

model Referral {
  id            String  @id @default(cuid())
  code          String  @unique
  referrerEmail String
  referrerName  String?

  commissionType  String @default("flat")
  commissionValue Int    @default(0)

  clicks      Int @default(0)
  signups     Int @default(0)
  conversions Int @default(0)
  totalEarned Int @default(0)
  totalPaid   Int @default(0)

  status String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([referrerEmail])
}
