# ============================================================
# Outbound Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="OutboundPro"
NODE_ENV=development

# ---- Database (Supabase) ----
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ---- Auth (Clerk) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_GROWTH_PRICE_ID=price_xxx
STRIPE_SCALE_PRICE_ID=price_xxx

# ---- Resend (Email) ----
RESEND_API_KEY=re_xxx
EMAIL_FROM="OutboundPro <hello@outboundpro.com>"

# ---- Upstash Redis ----
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ---- PostHog Analytics ----
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Supabase Storage ----
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# ---- Cal.com (Booking) ----
CAL_API_KEY=cal_xxx
CAL_WEBHOOK_SECRET=xxx
NEXT_PUBLIC_CAL_LINK="outboundpro/discovery"

# ---- Enrichment ----
APOLLO_API_KEY=xxx
CLEARBIT_API_KEY=xxx

# ---- Slack Notifications ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
SLACK_BOT_TOKEN=xoxb-xxx

# ---- Anthropic (AI Chatbot) ----
ANTHROPIC_API_KEY=sk-ant-xxx

# ---- Inngest (Workflows) ----
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=xxx

# ---- Sentry (Error Tracking) ----
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=xxx
