# ============================================================
# Outbound Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Accelrated Growth"
NEXT_PUBLIC_SUPPORT_EMAIL=support@accelratedgrowth.com
NODE_ENV=development

# ---- Database (Supabase) ----
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# ---- Auth ----
# Generate a strong secret: openssl rand -base64 32
AUTH_SECRET=your-secret-here-min-32-chars-CHANGE-THIS
# Demo mode: set true to run without DB/auth (shows demo data)
DEMO_MODE=false

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_GROWTH_PRICE_ID=price_xxx
STRIPE_SCALE_PRICE_ID=price_xxx

# ---- Gmail SMTP (Email) ----
# Use a Google App Password — NOT your regular Gmail password
# Generate at: myaccount.google.com/apppasswords (requires 2FA enabled)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM="Accelrated Growth <you@gmail.com>"

# ---- Upstash Redis ----
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ---- PostHog Analytics ----
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Meta Pixel ----
# Get from: business.facebook.com → Events Manager → Pixels → Your Pixel → Settings
NEXT_PUBLIC_META_PIXEL_ID=

# ---- Supabase Storage ----
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# ---- Calendly (Booking) ----
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/accelerateyourgrowthtoday

# ---- Enrichment ----
APOLLO_API_KEY=xxx
CLEARBIT_API_KEY=xxx

# ---- Slack Notifications ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
SLACK_BOT_TOKEN=xoxb-xxx

# ---- Anthropic (AI Chatbot) ----
ANTHROPIC_API_KEY=sk-ant-xxx

# ---- Inngest (Workflows) ----
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=xxx

# ---- Field Encryption (CRITICAL — set before any Integration records are created) ----
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=xxx

# ---- Dev manual sync trigger ----
# Generate: openssl rand -hex 20
CRON_SECRET=xxx

# ---- Notifications ----
TEAM_NOTIFICATION_EMAIL=abdomohamedd950@gmail.com

# ---- Instantly White-Label (Campaign Hub) ----
# Set this to your white-labeled Instantly URL once provisioned
# e.g. https://campaigns.yourdomain.com or https://app.yourdomain.com
NEXT_PUBLIC_INSTANTLY_URL=

# ---- Sentry (Error Tracking) ----
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=xxx
